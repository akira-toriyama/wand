<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
 "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Info.plist for the LOCAL dev build only. Selected by `package.sh --dev`
  (called from run.sh). Keeps a separate CFBundleIdentifier so the dev
  build and a co-installed Homebrew release can each hold their own
  Accessibility grant — no re-prompts when switching between them.
  CFBundleExecutable stays `wand` (same binary).
-->
<plist version="1.0">
<dict>
  <key>CFBundleIdentifier</key>
  <string>com.wand.wand.dev</string>
  <key>CFBundleName</key>
  <string>wand (dev)</string>
  <key>CFBundleDisplayName</key>
  <string>wand (dev)</string>
  <key>CFBundleExecutable</key>
  <string>wand</string>
  <key>CFBundleIconFile</key>
  <string>Wand</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>CFBundleShortVersionString</key>
  <string>4.0.0-dev</string>
  <key>CFBundleVersion</key>
  <string>1</string>
  <key>LSMinimumSystemVersion</key>
  <string>13.0</string>
  <key>LSUIElement</key>
  <true/>
  <key>NSPrincipalClass</key>
  <string>NSApplication</string>
  <key>NSAccessibilityUsageDescription</key>
  <string>wand (dev) needs Accessibility access to read the window under the cursor and dispatch actions to it.</string>
</dict>
</plist>
