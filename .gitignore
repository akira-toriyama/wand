# SwiftPM
.build/
.swiftpm/
# Package.resolved IS tracked since the sill dependency (atelier) — it
# locks the exact sill commit so CI / brew builds are reproducible.
*.xcodeproj/
*.xcworkspace/

# macOS
.DS_Store
*.swp

# App bundles produced by local build scripts (M5)
*.app/

# Icon generator scratch (scripts/make-icon.sh)
.icon-build/
Wand.iconset/

# Code signing (M5: setup-signing-cert.sh writes the identity name here)
.signing-id

# Logs (local dev)
/tmp/*.log
